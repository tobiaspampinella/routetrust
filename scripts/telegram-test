#!/usr/bin/env node
const { appendAgentLog, getRuntimeSnapshot, nowIso, writeProjectStatus, writeText } = require("./agent-runtime-lib.js");

async function main() {
  const token = process.env.TELEGRAM_BOT_TOKEN;
  const chatId = process.env.TELEGRAM_CHAT_ID;
  const reportPath = "docs/agent-reports/telegram-test.md";
  const snapshot = getRuntimeSnapshot();

  if (!token || !chatId) {
    const missing = [
      !token ? "TELEGRAM_BOT_TOKEN" : null,
      !chatId ? "TELEGRAM_CHAT_ID" : null,
    ].filter(Boolean);
    const message = `# Telegram Test

Generated: ${nowIso()}

STATUS: blocked

Telegram external delivery was not executed because required environment variables are missing.

Missing:
${missing.map((item) => `- ${item}`).join("\n")}

Instructions:
- Copy \`.env.example\` to \`.env.local\`.
- Add \`TELEGRAM_BOT_TOKEN\`.
- Add \`TELEGRAM_CHAT_ID\`.
- Re-run \`npm run telegram:test\`.

No token value was printed.
`;
    writeText(reportPath, message);
    writeProjectStatus(snapshot, {
      telegram: {
        status: "blocked",
        configured: false,
        missingEnv: missing,
        lastRun: nowIso(),
        report: reportPath,
      },
    });
    appendAgentLog("telegram-agent", "telegram-test blocked missing env");
    console.log("Telegram test blocked: TELEGRAM_BOT_TOKEN and/or TELEGRAM_CHAT_ID missing.");
    console.log(`Report: ${reportPath}`);
    return;
  }

  const response = await fetch(`https://api.telegram.org/bot${token}/sendMessage`, {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({
      chat_id: chatId,
      text: `RouteTrust runtime telegram-test ${nowIso()}`,
    }),
  });

  const body = await response.text();
  const status = response.ok ? "completed" : "failed";
  writeText(
    reportPath,
    `# Telegram Test

Generated: ${nowIso()}

STATUS: ${status}
HTTP_STATUS: ${response.status}

Token value was not printed.

Response preview:

\`\`\`text
${body.slice(0, 1000)}
\`\`\`
`,
  );

  writeProjectStatus(snapshot, {
    telegram: {
      status,
      configured: true,
      missingEnv: [],
      lastRun: nowIso(),
      httpStatus: response.status,
      report: reportPath,
    },
  });
  appendAgentLog("telegram-agent", `telegram-test ${status} http=${response.status}`);

  if (!response.ok) {
    console.error(`Telegram test failed with HTTP ${response.status}.`);
    process.exit(1);
  }

  console.log("Telegram test completed.");
  console.log(`Report: ${reportPath}`);
}

main().catch((error) => {
  appendAgentLog("telegram-agent", `telegram-test failed error=${error.message}`);
  console.error(error.stack || error.message);
  process.exit(1);
});
