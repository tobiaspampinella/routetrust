#!/usr/bin/env node
const { getSchedule, evaluateAgent } = require("./agent-scheduling-lib.js");

const schedule = getSchedule();
for (const agentId of Object.keys(schedule.agents)) {
  const result = evaluateAgent(agentId);
  console.log(`${agentId}: remainingCooldownMinutes=${result.cooldownRemainingMinutes}; decision=${result.status}`);
}
