#!/usr/bin/env node
const fs = require("node:fs");
const { nowIso, writeHeartbeat } = require("./agent-runtime-lib.js");
const { LAST_RUN_FILE, getLastRunState, getSchedule, runPackageScript, writeRuntimeStatusDocs, updateProjectStatusFromSchedule } = require("./agent-scheduling-lib.js");

function sleep(ms) {
  Atomics.wait(new Int32Array(new SharedArrayBuffer(4)), 0, 0, ms);
}

function readLastRunState() {
  try {
    return JSON.parse(fs.readFileSync(LAST_RUN_FILE, "utf8"));
  } catch {
    return getLastRunState();
  }
}

function saveLastRunState(lastRunState) {
  lastRunState.generatedAt = nowIso();
  fs.writeFileSync(LAST_RUN_FILE, `${JSON.stringify(lastRunState, null, 2)}\n`, "utf8");
}

function localDateKey(date) {
  const year = date.getFullYear();
  const month = String(date.getMonth() + 1).padStart(2, "0");
  const day = String(date.getDate()).padStart(2, "0");
  return `${year}-${month}-${day}`;
}

function shouldRunDailySummary(schedule, now) {
  const targetHour = Number(schedule.scheduler.dailySummaryHourLocal || 7);
  if (now.getHours() !== targetHour) return false;
  const lastRunState = readLastRunState();
  const lastDailySummaryDate = String(lastRunState.scheduler?.lastDailySummaryDate || "");
  const today = localDateKey(now);
  if (lastDailySummaryDate === today) return false;
  lastRunState.scheduler = {
    ...(lastRunState.scheduler || {}),
    lastDailySummaryDate: today,
  };
  saveLastRunState(lastRunState);
  return true;
}

function runCycle() {
  const watchdog = runPackageScript("watchdog:once");
  const runner = runPackageScript("agent:runner");
  const schedule = getSchedule();
  const now = new Date();
  let daily = { status: 0 };

  if (shouldRunDailySummary(schedule, now)) {
    daily = runPackageScript("ops:daily-summary");
  }

  const summary = writeRuntimeStatusDocs();
  updateProjectStatusFromSchedule(summary, {
    watchdog: {
      status: watchdog.status === 0 ? "healthy" : "warning",
      lastRun: nowIso(),
    },
  });

  writeHeartbeat("scheduler", {
    status: runner.status === 0 ? "running" : "warning",
    currentTask: "scheduler-cycle",
    lastOutput: `watchdog=${watchdog.status}; runner=${runner.status}; daily=${daily.status}`,
    errors: [watchdog, runner, daily].filter((item) => item.status !== 0).map((item) => `exit ${item.status}`),
    pid: process.pid,
    mode: "running",
  });

  console.log(`cycle ${nowIso()} watchdog=${watchdog.status} runner=${runner.status} daily=${daily.status}`);
  return watchdog.status !== 0 || runner.status !== 0 || daily.status !== 0 ? 1 : 0;
}

function main() {
  const watch = process.argv.includes("--watch");
  const schedule = getSchedule();
  const tickMs = Number(schedule.scheduler.tickMinutes || 30) * 60 * 1000;

  do {
    runCycle();
    if (!watch) break;
    sleep(tickMs);
  } while (watch);
}

main();
