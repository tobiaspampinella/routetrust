#!/usr/bin/env node
const { runPackageScript } = require("./agent-runtime-lib.js");

const result = runPackageScript("qa:smoke");
if (result.stdout.trim()) console.log(result.stdout.trim());
if (result.stderr.trim()) console.error(result.stderr.trim());

if ((result.stdout + result.stderr).includes("spawn EPERM")) {
  console.error("BLOCKED: Chromium launch is denied by the current environment (spawn EPERM).");
}

process.exit(result.status);
