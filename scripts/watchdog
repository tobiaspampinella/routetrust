#!/usr/bin/env node
const { nowIso, readJson, readProjectStatus, runPackageScript, writeJson, writeProjectStatus, writeText } = require("./agent-runtime-lib.js");
const { getLastRunState, getSchedule, gitState, summarizeScheduleState } = require("./agent-scheduling-lib.js");

const WATCHDOG_STATE_FILE = "runtime/watchdog-state.json";

function sleep(ms) {
  Atomics.wait(new Int32Array(new SharedArrayBuffer(4)), 0, 0, ms);
}

async function checkServer() {
  const candidates = [
    process.env.APP_URL ? { appUrl: process.env.APP_URL, healthUrl: `${process.env.APP_URL.replace(/\/$/, "")}/api/health` } : null,
    process.env.NEXT_PUBLIC_APP_URL
      ? {
          appUrl: process.env.NEXT_PUBLIC_APP_URL,
          healthUrl: `${process.env.NEXT_PUBLIC_APP_URL.replace(/\/$/, "")}/api/health`,
        }
      : null,
    { appUrl: "http://127.0.0.1:3000", healthUrl: "http://127.0.0.1:3000/api/health" },
    { appUrl: "http://127.0.0.1:3001", healthUrl: "http://127.0.0.1:3001/api/health" },
  ].filter(Boolean);

  let lastFailure = { status: "off", url: "none", detail: "No health endpoint candidate available." };
  for (const candidate of candidates) {
    try {
      const controller = new AbortController();
      const timeout = setTimeout(() => controller.abort(), 2500);
      const response = await fetch(candidate.healthUrl, { signal: controller.signal });
      clearTimeout(timeout);
      if (response.ok) return { status: "on", url: candidate.appUrl, detail: `HTTP ${response.status}` };
      lastFailure = { status: "warning", url: candidate.appUrl, detail: `HTTP ${response.status}` };
    } catch (error) {
      lastFailure = { status: "off", url: candidate.appUrl, detail: error.message };
    }
  }

  return lastFailure;
}

function failedStatus(value) {
  return /\bfailed|broken|blocked\b/.test(String(value || "").toLowerCase());
}

function p0Blockers(projectStatus) {
  const blockers = [];
  const buildStatus = String(projectStatus.build?.status || "").toLowerCase();
  const smokeStatus = String(projectStatus.smokeBrowser?.status || "").toLowerCase();
  const betaStatus = String(projectStatus.beta?.status || "").toLowerCase();

  if (failedStatus(buildStatus)) blockers.push("build failed");
  if (failedStatus(smokeStatus)) blockers.push("smoke failed");
  if (failedStatus(betaStatus)) blockers.push("beta-check failed");
  for (const bug of projectStatus.bugs || []) {
    if (String(bug.severity || "").toUpperCase() === "P0") blockers.push(`P0 bug: ${bug.title || bug.id || "unknown"}`);
  }
  return blockers;
}

function notificationForState(projectStatus, blockers, priorState) {
  const priorStable = Boolean(priorState?.lastStableReady);
  const stableNow = Boolean(projectStatus.classifications?.betaStableReady);

  if (blockers.length > 0) {
    return {
      key: `p0:${blockers.join("|")}`,
      message: `RouteTrust watchdog alert ${nowIso()}\n${blockers.join("\n")}`,
    };
  }

  if (stableNow && !priorStable) {
    return {
      key: `stable:${projectStatus.beta?.lastRun || nowIso()}`,
      message: `RouteTrust stable build achieved ${projectStatus.beta?.lastRun || nowIso()}`,
    };
  }

  return null;
}

function maybeNotifyTelegram(notification, priorState) {
  if (!notification) return { sent: false, reason: "no_event" };
  if (priorState?.lastNotificationKey === notification.key) return { sent: false, reason: "duplicate" };
  const result = runPackageScript("telegram:notify", [`--message="${notification.message.replace(/"/g, "'")}"`]);
  return {
    sent: result.status === 0,
    reason: result.status === 0 ? "sent" : "failed",
    status: result.status,
    stderr: result.stderr,
  };
}

async function runOnce() {
  const summary = summarizeScheduleState();
  const projectStatus = readProjectStatus();
  const priorState = readJson(WATCHDOG_STATE_FILE, {});
  const server = await checkServer();
  const repo = gitState();
  const lastRun = getLastRunState();
  const blockers = p0Blockers(projectStatus);
  const issues = [
    server.status === "off" ? "server off" : null,
    projectStatus.scheduler?.status === "stopped" ? "scheduler off" : null,
    !repo.remoteConfigured ? "github remote missing" : null,
    ...(blockers.length > 0 ? blockers : []),
  ].filter(Boolean);

  const schedule = getSchedule();
  const eligibleAgents = blockers.length > 0
    ? Object.keys(schedule.agents).filter((agentId) => {
        const priorityOverride = schedule.agents[agentId].priorityOverride || [];
        return priorityOverride.includes("P0");
      })
    : [];

  const notification = notificationForState(projectStatus, blockers, priorState);
  const telegram = maybeNotifyTelegram(notification, priorState);

  const lines = [
    "# Watchdog Report",
    "",
    `Generated: ${nowIso()}`,
    "",
    `- Server: ${server.status} (${server.url})`,
    `- Scheduler: ${projectStatus.scheduler?.status || "unknown"}`,
    `- Last beta-check: ${projectStatus.beta?.lastRun || "never"}`,
    `- Last agent run file: ${lastRun.generatedAt || "never"}`,
    `- Telegram status: ${projectStatus.telegram?.status || "unknown"}`,
    `- GitHub remote configured: ${repo.remoteConfigured ? "yes" : "no"}`,
    `- Smoke status: ${projectStatus.smokeBrowser?.status || "unknown"}`,
    "",
    "## P0 Blockers",
    "",
    ...(blockers.length > 0 ? blockers.map((item) => `- ${item}`) : ["- none"]),
    "",
    "## Eligible Agents",
    "",
    ...(eligibleAgents.length > 0 ? eligibleAgents.map((item) => `- ${item}`) : ["- none"]),
    "",
    "## Notification",
    "",
    `- Event: ${notification ? notification.key : "none"}`,
    `- Telegram: ${telegram.reason}`,
  ];

  writeText("docs/agent-reports/watchdog.md", `${lines.join("\n")}\n`);
  writeJson(WATCHDOG_STATE_FILE, {
    lastRun: nowIso(),
    lastNotificationKey: telegram.sent && notification ? notification.key : priorState.lastNotificationKey || null,
    lastStableReady: Boolean(projectStatus.classifications?.betaStableReady),
  });
  writeProjectStatus({ agents: [], activeTasks: [] }, {
    ...projectStatus,
    server: {
      status: server.status,
      url: server.url,
      detail: server.detail,
      checkedAt: nowIso(),
    },
    watchdog: {
      status: blockers.length > 0 ? "blocked" : issues.length > 0 ? "warning" : "healthy",
      issues,
      eligibleForRun: eligibleAgents,
      lastRun: nowIso(),
      lastNotificationKey: telegram.sent && notification ? notification.key : priorState.lastNotificationKey || null,
      report: "docs/agent-reports/watchdog.md",
    },
    tokenBudget: {
      ...projectStatus.tokenBudget,
      updatedAt: summary.generatedAt,
    },
  });

  console.log(lines.join("\n"));
  if (blockers.length > 0) process.exit(1);
}

async function main() {
  const watch = process.argv.includes("--watch");
  const tickMs = Number(getSchedule().scheduler.watchdogMinutes || 30) * 60 * 1000;
  do {
    await runOnce();
    if (!watch) break;
    sleep(tickMs);
  } while (watch);
}

main().catch((error) => {
  console.error(error.stack || error.message);
  process.exit(1);
});
