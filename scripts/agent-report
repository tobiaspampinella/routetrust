#!/usr/bin/env node
const {
  checkLocks,
  getRuntimeSnapshot,
  printStatus,
  recordStatusLog,
  writeAgentReport,
  writeProjectStatus,
  writeRuntimeStatusReport,
} = require("./agent-runtime-lib.js");

const snapshot = getRuntimeSnapshot();
const lockState = checkLocks(snapshot.activeTasks);
writeRuntimeStatusReport(snapshot, {
  "Lock Validation": lockState.ok
    ? "No lock inconsistencies detected."
    : lockState.inconsistencies.map((item) => `- ${item}`).join("\n"),
});
const reportPath = writeAgentReport(snapshot);
writeProjectStatus(snapshot, {
  locks: {
    status: lockState.ok ? "healthy" : "warning",
    active: lockState.activeLocks,
    inconsistencies: lockState.inconsistencies,
    lastUpdated: snapshot.generatedAt,
  },
});
recordStatusLog(snapshot);

printStatus(snapshot);
console.log("");
console.log(`Report created: ${reportPath}`);

if (
  snapshot.validation.missing.length > 0 ||
  snapshot.validation.invalidStatuses.length > 0 ||
  lockState.inconsistencies.length > 0
) {
  process.exit(1);
}
