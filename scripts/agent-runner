#!/usr/bin/env node
const { dispatchAgent, getSchedule, summarizeScheduleState, updateProjectStatusFromSchedule, writeRuntimeStatusDocs } = require("./agent-scheduling-lib.js");

function main() {
  const schedule = getSchedule();
  const agentArg = process.argv[2];
  const force = process.argv.includes("--force");
  const targetAgents = agentArg ? [agentArg] : Object.keys(schedule.agents);
  const reports = targetAgents.map((agentId) => dispatchAgent(agentId, { force }));

  const summary = writeRuntimeStatusDocs();
  updateProjectStatusFromSchedule(summary);

  for (const report of reports) {
    console.log(`${report.agentId}: ${report.status}; reason=${report.reason}`);
  }

  const failed = reports.filter((report) => report.status === "FAILED");
  if (failed.length > 0) process.exit(1);
}

main();
