# RouteTrust local development environment.
# Copy to `.env.local` and adjust only for your machine.

DATABASE_URL=postgresql://routetrust:routetrust_local_password@localhost:5432/routetrust_local?schema=public
AUTH_SECRET=
ROUTEPULSE_DEMO_SECRET=
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_MAP_PROVIDER=maplibre
NEXT_PUBLIC_TILE_URL=
OSRM_BASE_URL=
OPENROUTE_API_KEY=
DEMO_MODE=true
NODE_ENV=development
