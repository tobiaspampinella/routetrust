{
  "version": "1.0",
  "project": "RouteTrust",
  "mode": "controlled-local-automation",
  "description": "Cadencia operativa de OpenCode/minimax-m3 como soporte mientras Codex GPT-5.5 recupera tokens. No ejecuta LLM workers autonomos. Cada agente corre solo si pasa el gating. P0 puede saltar cooldown. P1 puede acortarlo. P2 no.",
  "owner": "routetrust-node-orchestrator",
  "generatedAt": "2026-06-01T21:00:00.000Z",
  "cooldowns": {
    "P0": "may-bypass",
    "P1": "may-shorten",
    "P2": "no-bypass",
    "P3": "no-bypass"
  },
  "skipCodes": [
    "SKIPPED_NO_CHANGES",
    "SKIPPED_NO_TASKS",
    "SKIPPED_COOLDOWN",
    "SKIPPED_MANUAL_REQUIRED",
    "SKIPPED_REQUIRES_CODEX",
    "SKIPPED_BLOCKED",
    "SKIPPED_DRIFT",
    "SKIPPED_LOCKED_FILES"
  ],
  "gating": [
    "git-changed-since-last-execution",
    "open-task-exists",
    "P0-or-P1-signal",
    "interval-or-fixed-window-reached",
    "cooldown-not-active",
    "no-locked-file-conflict",
    "human-approval-not-required",
    "agent-permitted-to-modify-area",
    "db-auth-security-impact-assessed",
    "codex-required-check"
  ],
  "agents": {
    "runtime-watchdog": {
      "label": "Runtime Watchdog Agent",
      "intervalMinutes": 30,
      "canModifyCode": false,
      "canCommit": false,
      "canPush": false,
      "priority": "high",
      "scope": "Monitoreo barato. Solo lee project-status, watchdog-state y agent-last-run. Reporta drift.",
      "triggers": ["server-down", "scheduler-warn", "beta-fail", "smoke-fail", "watchdog-state-stale"],
      "canRun247": true,
      "writes": ["runtime/heartbeats/", "runtime/opencode/queue.json"]
    },
    "bug-triage": {
      "label": "Bug Triage Agent",
      "intervalMinutes": 60,
      "canModifyCode": false,
      "canCommit": false,
      "canPush": false,
      "priority": "high",
      "scope": "Clasifica bug reports por categoria/severidad y los enruta. No modifica codigo fuente.",
      "triggers": ["new-bug-report", "P0-bug", "P1-bug", "unrouted-bug-backlog"],
      "canRun247": true,
      "writes": ["data/runtime/bug-reports.json", "runtime/opencode/queue.json"]
    },
    "node-orchestrator": {
      "label": "RouteTrust Node Orchestrator",
      "intervalMinutes": 120,
      "cooldownMinutes": 90,
      "canModifyCode": true,
      "onlyFor": ["P0", "P1"],
      "canCommit": true,
      "canPush": false,
      "priority": "critical",
      "scope": "Coordina, clasifica bloqueos, programa cadencia, genera next-actions. Implementa solo P0/P1 pequenos.",
      "triggers": ["drift-detected", "blocker-changed", "P0", "P1", "handoff-drift", "schedule-review"],
      "canRun247": false,
      "writes": ["docs/", "runtime/opencode/", "scripts/agent-scheduling-lib.js (read-only)"]
    },
    "qa-analyst": {
      "label": "QA Analyst Agent",
      "intervalMinutes": 240,
      "cooldownMinutes": 180,
      "canModifyCode": false,
      "canCommit": false,
      "canPush": false,
      "priority": "high",
      "scope": "Ejecuta qa:smoke y qa:security si pasan gating. Solo valida, no implementa.",
      "triggers": ["smoke-due", "beta-fail", "regression-signal", "P1-bug-cluster"],
      "canRun247": false,
      "writes": ["docs/QA.md", "docs/QA_SECURITY_REPORT.md", "runtime/opencode/queue.json"]
    },
    "github-repository": {
      "label": "GitHub Repository Agent",
      "intervalMinutes": 360,
      "cooldownMinutes": 360,
      "pushCooldownMinutes": 360,
      "canModifyCode": true,
      "allowedAreas": ["README", "docs", ".github", "CHANGELOG"],
      "canCommit": true,
      "canPush": true,
      "noForcePush": true,
      "priority": "medium-high",
      "scope": "Sincroniza repo publico. Prepara commits en areas permitidas. Push max cada 6h. No force push.",
      "triggers": ["upstream-missing", "github-drift", "public-docs-stale", "schedule-window"],
      "canRun247": false,
      "writes": ["README.md", "README.es.md", "CHANGELOG.md", "docs/", ".github/"]
    },
    "local-model-documentation": {
      "label": "Local Model Documentation Agent",
      "intervalMinutes": 180,
      "cooldownMinutes": 120,
      "canModifyCode": false,
      "canCommit": false,
      "canPush": false,
      "priority": "medium",
      "scope": "Documentacion operativa, resumenes bilingues, handoffs. Sin cambios de producto.",
      "triggers": ["docs-stale", "bilingual-drift", "handoff-needed"],
      "canRun247": true,
      "writes": ["docs/", "runtime/opencode/"]
    },
    "ux-ui-designer": {
      "label": "UX/UI Designer Agent",
      "intervalMinutes": 1440,
      "cooldownMinutes": 1200,
      "canModifyCode": true,
      "onlyWithAssignedTask": true,
      "canCommit": false,
      "canPush": false,
      "priority": "medium",
      "scope": "Auditoria visual. Modifica diseno solo con task asignada (UXR-*). No backend.",
      "triggers": ["UXR-task-assigned", "P1-ux-regression", "daily-window"],
      "canRun247": false,
      "writes": ["docs/design/", "src/components/**/design-system/*"]
    },
    "cybersecurity": {
      "label": "Cybersecurity Agent",
      "intervalMinutes": 1440,
      "cooldownMinutes": 1200,
      "canModifyCode": false,
      "canCommit": false,
      "canPush": false,
      "priority": "critical",
      "scope": "Auditoria de seguridad. Puede bloquear release. Puede tocar .gitignore y docs de seguridad. No publica vulnerabilidades.",
      "triggers": ["auth-change", "env-change", "api-change", "secret-drift", "daily-window"],
      "canRun247": false,
      "writes": ["docs/SECURITY_AUDIT.md", ".gitignore (minor)"]
    },
    "database-prisma": {
      "label": "Database/Prisma Agent",
      "trigger": "task-only",
      "canModifyCode": true,
      "requiresP0OrP1": true,
      "canCommit": true,
      "canPush": false,
      "priority": "critical",
      "scope": "Implementacion DB/Prisma. Solo con task P0/P1. No migraciones destructivas. No inventar DATABASE_URL.",
      "triggers": ["DB-task", "Prisma-blocker"],
      "canRun247": false,
      "writes": ["prisma/", "src/lib/storage/", "scripts/"]
    },
    "backend-real": {
      "label": "Backend Real Agent",
      "trigger": "task-only",
      "canModifyCode": true,
      "requiresP0OrP1": true,
      "canCommit": true,
      "canPush": false,
      "priority": "critical",
      "scope": "Implementacion backend real (APIs, RBAC, tenant isolation). Solo con task P0/P1. No toca UI salvo integracion minima.",
      "triggers": ["API-task", "auth-task", "RBAC-task"],
      "canRun247": false,
      "writes": ["src/app/api/", "src/lib/"]
    },
    "frontend-product": {
      "label": "Frontend Product Agent",
      "trigger": "task-only",
      "canModifyCode": true,
      "canCommit": true,
      "canPush": false,
      "priority": "medium-high",
      "scope": "Implementacion UI con task asignada. No DB/auth.",
      "triggers": ["UI-task", "P1-ux"],
      "canRun247": false,
      "writes": ["src/app/**/page.tsx", "src/components/**"]
    },
    "devops-staging": {
      "label": "DevOps/Staging Agent",
      "trigger": "task-only",
      "canModifyCode": true,
      "canCommit": true,
      "canPush": false,
      "priority": "high",
      "scope": "Deploy/env/CI/staging. No secrets.",
      "triggers": ["deploy-task", "staging-task", "ci-fail"],
      "canRun247": false,
      "writes": [".github/workflows/", "docker-compose.yml", "scripts/devops-doctor"]
    },
    "maps-tracking": {
      "label": "Maps & Tracking Agent",
      "trigger": "task-only",
      "canModifyCode": true,
      "canCommit": true,
      "canPush": false,
      "priority": "medium-high",
      "scope": "Map provider abstraction, map docs, tracking. No APIs pagas sin autorizacion humana.",
      "triggers": ["maps-task", "tracking-task"],
      "canRun247": false,
      "writes": ["src/components/shared/RouteMapPlaceholder.tsx", "src/lib/maps/*", "docs/design/"]
    },
    "product-chief-strategy": {
      "label": "Product/Chief Strategy Agent",
      "intervalMinutes": 10080,
      "cooldownMinutes": 7200,
      "canModifyCode": false,
      "canCommit": false,
      "canPush": false,
      "priority": "medium",
      "scope": "Revision semanal de estrategia, GTM, scope, posicionamiento. Sin cambios de codigo.",
      "triggers": ["weekly-window", "manual-request"],
      "canRun247": false,
      "writes": ["docs/product/", "docs/ROADMAP.md"]
    }
  },
  "agents247": [
    "runtime-watchdog",
    "bug-triage",
    "local-model-documentation"
  ],
  "agentsRecurrent": [
    "node-orchestrator",
    "qa-analyst",
    "github-repository",
    "ux-ui-designer",
    "cybersecurity"
  ],
  "agentsTaskOnly": [
    "database-prisma",
    "backend-real",
    "frontend-product",
    "devops-staging",
    "maps-tracking"
  ],
  "codexRequired": [
    "DB-migrations-critical",
    "auth-real",
    "RBAC-final",
    "tenant-isolation-final",
    "deploy-real",
    "security-final-verdict",
    "refactors-large",
    "force-push",
    "staging-decision",
    "production-decision"
  ]
}
